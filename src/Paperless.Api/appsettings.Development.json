{
  "Logging": {
    "LogLevel": {
      "Default": "Debug",
      "Microsoft.AspNetCore": "Information"
    }
  },

  "Database": {
    "Provider": "SQLite",
    "ConnectionString": "Data Source=paperless_dev.db"
  },

  "Hangfire": {
    "StorageProvider": "Memory",
    "WorkerCount": 2,
    "Queues": [ "default" ],
    "EnableDashboard": true
  },

  "Cors": {
    "AllowedOrigins": [
      "http://localhost:4200",
      "http://localhost:5130"
    ]
  },

  "Serilog": {
    "MinimumLevel": {
      "Default": "Debug",
      "Override": {
        "Microsoft.AspNetCore": "Information",
        "Microsoft.EntityFrameworkCore": "Warning",
        "Hangfire": "Debug",
        "Paperless.Core": "Debug",
        "Paperless.Infrastructure": "Debug",
        "Paperless.Api": "Debug"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "formatter": "Serilog.Formatting.Json.JsonFormatter, Serilog"
        }
      },
      {
        "Name": "Seq",
        "Args": {
          "serverUrl": "http://localhost:5341",
          "restrictedToMinimumLevel": "Debug",
          "apiKey": ""
        }
      }
    ]
  }
}
