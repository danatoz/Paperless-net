# Paperless .NET — Docker Compose environment variables
# Copy this file as .env in the same directory as docker-compose.yml
# or export these variables in your shell.

COMPOSE_PROJECT_NAME=paperless-dotnet

# ── Database ──────────────────────────────────────────────────────
# PostgreSQL is the primary database. Connection string is used by
# both EF Core (Database:ConnectionString) and Hangfire
# (Hangfire:ConnectionString).
POSTGRES_DB=paperless
POSTGRES_USER=paperless
POSTGRES_PASSWORD=paperless

# ── File storage ──────────────────────────────────────────────────
# Base directory for document files (originals, archive, thumbnails,
# previews). Mounted as a Docker volume at /app/data inside the API
# container.
PAPERLESS_DATA_DIR=/app/data
